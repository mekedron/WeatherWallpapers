    "Delete “%@”?" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Удалить «%@»?" } } } },
    "All 120 images of this set will be deleted." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Все 120 изображений этого набора будут удалены." } } } },
