    "Version" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Версия" } } } },
    "Source Code on GitHub" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Исходный код на GitHub" } } } },
    "Free & open source. Your images and API keys stay on your devices." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Бесплатно и с открытым кодом. Ваши изображения и API-ключи остаются на ваших устройствах." } } } },
    "Next" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Далее" } } } },
    "Get Started" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Начать" } } } },
    "Not Now" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Не сейчас" } } } },
    "Location access granted" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Доступ к геолокации разрешён" } } } },
    "onboarding.welcome.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Wallpapers that follow the sky" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Обои, которые следуют за небом" } }
      }
    },
    "onboarding.welcome.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Turn one image into 120 wallpapers — one for every weather condition and time of day. Your wallpaper will always match what's outside." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Одна картинка превращается в 120 обоев — на каждую погоду и время суток. Обои всегда будут совпадать с тем, что за окном." } }
      }
    },
    "onboarding.how.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "How it works" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Как это работает" } }
      }
    },
    "onboarding.how.step1" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Create a wallpaper set: pick an image from Photos or Files, or generate one with AI." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Создайте набор обоев: выберите картинку из Фото или Файлов, либо сгенерируйте её нейросетью." } }
      }
    },
    "onboarding.how.step2" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The app generates all 120 variants with your own API key (OpenAI or Nano Banana) and stores them in iCloud Drive." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Приложение генерирует все 120 вариантов с вашим API-ключом (OpenAI или Nano Banana) и хранит их в iCloud Drive." } }
      }
    },
    "onboarding.how.step3" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "A Shortcuts automation sets the right wallpaper for the current weather — the built-in guide walks you through it." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Автоматизация в Быстрых командах ставит нужные обои под текущую погоду — встроенный гайд всё покажет." } }
      }
    },
    "onboarding.location.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Weather at your location" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Погода в вашем месте" } }
      }
    },
    "onboarding.location.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "To pick the matching wallpaper, the Shortcuts action needs your approximate location. Weather comes from Open-Meteo — free, no account. Your location never leaves the device." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Чтобы подобрать подходящие обои, действию Быстрых команд нужна ваша примерная геолокация. Погода берётся из Open-Meteo — бесплатно и без аккаунта. Локация не покидает устройство." } }
      }
    },
    "guide.intro.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Automatic weather wallpapers" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Автоматические погодные обои" } }
      }
    },
    "guide.intro.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Apps can't change your wallpaper directly — Apple doesn't allow it. But together with the Shortcuts app it works great: the “Get Current Wallpaper” action returns the image matching the weather and time of day at your location, and a system action sets it as the wallpaper." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Приложения не могут менять обои напрямую — Apple это не разрешает. Но в связке с Быстрыми командами всё отлично работает: действие «Get Current Wallpaper» возвращает картинку под текущую погоду и время суток в вашем месте, а системное действие ставит её на обои." } }
      }
    },
    "guide.shortcut.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Create the shortcut (iPhone & iPad)" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Создайте быструю команду (iPhone и iPad)" } }
      }
    },
    "guide.shortcut.step1" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Open the Shortcuts app and create a new shortcut." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Откройте приложение «Быстрые команды» и создайте новую команду." } }
      }
    },
    "guide.shortcut.step2" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Add the “Get Current Wallpaper” action from Weather Wallpapers and pick your wallpaper set." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Добавьте действие «Get Current Wallpaper» от Weather Wallpapers и выберите свой набор обоев." } }
      }
    },
    "guide.shortcut.step3" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Add the system “Set Wallpaper” action and pass the image from the previous step into it." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Добавьте системное действие «Установить обои» и передайте в него изображение из предыдущего шага." } }
      }
    },
    "guide.shortcut.step4" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Run the shortcut once manually to grant the permissions it asks for." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Запустите команду один раз вручную, чтобы выдать запрошенные разрешения." } }
      }
    },
    "guide.automation.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Run it on a schedule" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Запуск по расписанию" } }
      }
    },
    "guide.automation.step1" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "In Shortcuts, open the Automation tab and create a Personal Automation → “Time of Day”." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "В «Быстрых командах» откройте вкладку «Автоматизация» и создайте автоматизацию «Время суток»." } }
      }
    },
    "guide.automation.step2" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Pick a time, choose “Run Immediately” and select your shortcut." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Выберите время, включите «Выполнять сразу» и укажите свою команду." } }
      }
    },
    "guide.automation.step3" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Add several automations (e.g. sunrise, noon, sunset, late evening — or every hour) so the wallpaper follows the sky." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Добавьте несколько автоматизаций (например: рассвет, полдень, закат, поздний вечер — или каждый час), чтобы обои следовали за небом." } }
      }
    },
    "guide.mac.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "On the Mac" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "На Mac" } }
      }
    },
    "guide.mac.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Shortcuts on macOS has no “Set Wallpaper” action. After “Get Current Wallpaper”, add “Save File” to store the image, then a “Run AppleScript” action that sets the desktop picture:" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "В Быстрых командах на macOS нет действия «Установить обои». После «Get Current Wallpaper» добавьте «Сохранить файл», а затем действие «Выполнить AppleScript», которое ставит картинку на рабочий стол:" } }
      }
    },
    "guide.note" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Weather comes from Open-Meteo and your location never leaves the device. Wallpapers live in iCloud Drive, so the same automation works on every device." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Погода берётся из Open-Meteo, ваша геолокация не покидает устройство. Обои лежат в iCloud Drive, поэтому одна и та же автоматизация работает на всех устройствах." } }
      }
    },
    "Weather Statistics" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Статистика погоды" } } } },
    "No weather checks recorded yet. Statistics build up as your Shortcuts automation asks for the current wallpaper." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Проверок погоды пока не записано. Статистика будет накапливаться, когда автоматизация Команд запрашивает текущие обои." } } } },
    "Counted on this device each time a shortcut asks for the current wallpaper. Nothing leaves your device." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Считается на этом устройстве при каждом запросе текущих обоев командой. Данные не покидают устройство." } } } },
    "%lld checks · %lld days" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "%lld проверок · %lld дней" } } } },
    "since %@" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "с %@" } } } },
    "%lld×" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "%lld×" } } } },
    "All 30 conditions have occurred at your location." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Все 30 условий уже встречались в вашей локации." } } } },
    "These never occurred at your location — you can skip generating them to save on API costs." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Эти условия ни разу не встречались в вашей локации — их можно не генерировать и сэкономить на API." } } } },
    "Never Observed" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Не встречались" } } } },
    "%lld of %lld" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "%lld из %lld" } } } },
    "Collect Statistics" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Собирать статистику" } } } },
    "Record" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Записывать" } } } },
    "Every check" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Каждую проверку" } } } },
    "Up to 6 a day" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "До 6 в день" } } } },
    "Up to 3 a day" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "До 3 в день" } } } },
    "Once a day" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Раз в день" } } } },
    "Keep" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Хранить" } } } },
    "1 Month" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "1 месяц" } } } },
    "3 Months" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "3 месяца" } } } },
    "6 Months" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "6 месяцев" } } } },
    "1 Year" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "1 год" } } } },
    "2 Years" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "2 года" } } } },
    "Clear Statistics…" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Очистить статистику…" } } } },
    "Clear Weather Statistics?" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Очистить статистику погоды?" } } } },
    "Clear Statistics" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Очистить статистику" } } } },
    "This removes the recorded weather history from this device. Wallpapers are not affected." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "История погоды будет удалена с этого устройства. Обои не пострадают." } } } },
    "Capping the records keeps automations that check the weather many times a day from skewing the picture." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Ограничение записей не даёт автоматизациям, проверяющим погоду много раз в день, искажать картину." } } } },
    "Total on This Device" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Всего на этом устройстве" } } } },
    "Wallpaper Sets" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Наборы обоев" } } } },
    "Caches" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Кэши" } } } },
    "Metadata" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Метаданные" } } } },
    "Calculating…" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Подсчёт…" } } } },
    "Clear Caches" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Очистить кэши" } } } },
    "Sizes reflect space used on this device. Wallpapers not yet downloaded from iCloud take almost no space. Caches hold only regenerable data and are safe to clear." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Размеры — место, занятое на этом устройстве. Обои, ещё не загруженные из iCloud, почти не занимают места. Кэши содержат только восстановимые данные, их безопасно очищать." } } } }
  },
  "version" : "1.0"
}
